# keycloak.localhost reverse proxy with automatic TLS (self-signed for localhost)
keycloak.localhost:443 {
    tls internal

    # Increase buffer sizes for Keycloak's large OIDC responses
    reverse_proxy keycloak:8080 {
        header_up X-Forwarded-Proto "https"
        header_up X-Forwarded-Port  "8443"
        flush_interval -1
    }
}

# Redirect plain HTTP to HTTPS
keycloak.localhost:80 {
    redir https://keycloak.localhost:8443{uri} permanent
}

# device-login.localhost reverse proxy
device-login.localhost:443 {
    tls internal

    reverse_proxy device-login:8081 {
        header_up X-Forwarded-Proto "https"
        header_up X-Forwarded-Port  "8443"
    }
}

device-login.localhost:80 {
    redir https://device-login.localhost:8443{uri} permanent
}

# app-mock.localhost — mobile app mock UI
# /api/* is proxied to device-login so the browser stays same-origin (no CORS)
app-mock.localhost:443 {
    tls internal

    handle /api/* {
        reverse_proxy device-login:8081 {
            header_up X-Forwarded-Proto "https"
            header_up X-Forwarded-Port  "8443"
        }
    }

    handle {
        reverse_proxy app-mock:80
    }
}

app-mock.localhost:80 {
    redir https://app-mock.localhost:8443{uri} permanent
}

# admin.localhost — admin UI
# /api/* is proxied to device-login (admin endpoints require Basic Auth)
admin.localhost:443 {
    tls internal

    handle /api/* {
        reverse_proxy device-login:8081 {
            header_up X-Forwarded-Proto "https"
            header_up X-Forwarded-Port  "8443"
        }
    }

    handle {
        reverse_proxy admin-mock:80
    }
}

admin.localhost:80 {
    redir https://admin.localhost:8443{uri} permanent
}

# home.localhost — developer start page with links to all services
home.localhost:443 {
    tls internal

    handle {
        reverse_proxy home:80
    }
}

home.localhost:80 {
    redir https://home.localhost:8443{uri} permanent
}

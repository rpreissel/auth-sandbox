# keycloak.localhost reverse proxy with automatic TLS (self-signed for localhost)
keycloak.localhost:443 {
    tls internal

    # Increase buffer sizes for Keycloak's large OIDC responses
    reverse_proxy keycloak:8080 {
        header_up X-Forwarded-Proto "https"
        header_up X-Forwarded-Port  "8443"
        flush_interval -1
    }
}

# Redirect plain HTTP to HTTPS
keycloak.localhost:80 {
    redir https://keycloak.localhost:8443{uri} permanent
}

# auth-service.localhost reverse proxy → auth-service
auth-service.localhost:443 {
    tls internal

    reverse_proxy auth-service:8083 {
        header_up X-Forwarded-Proto "https"
        header_up X-Forwarded-Port  "8443"
    }
}

auth-service.localhost:80 {
    redir https://auth-service.localhost:8443{uri} permanent
}

# app-mock.localhost — mobile app mock UI
# /api/* is proxied to auth-service so the browser stays same-origin (no CORS)
app-mock.localhost:443 {
    tls internal

    handle /api/* {
        reverse_proxy auth-service:8083 {
            header_up X-Forwarded-Proto "https"
            header_up X-Forwarded-Port  "8443"
        }
    }

    handle {
        reverse_proxy app-mock:80
    }
}

app-mock.localhost:80 {
    redir https://app-mock.localhost:8443{uri} permanent
}

# admin.localhost — admin UI
# /api/* is proxied to auth-service (admin endpoints require Basic Auth)
admin.localhost:443 {
    tls internal

    handle /api/* {
        reverse_proxy auth-service:8083 {
            header_up X-Forwarded-Proto "https"
            header_up X-Forwarded-Port  "8443"
        }
    }

    handle {
        reverse_proxy admin-mock:80
    }
}

admin.localhost:80 {
    redir https://admin.localhost:8443{uri} permanent
}

# home.localhost — developer start page with links to all services
home.localhost:443 {
    tls internal

    handle {
        reverse_proxy home:80
    }
}

home.localhost:80 {
    redir https://home.localhost:8443{uri} permanent
}

# sso-proxy.localhost — SSO browser transfer (served by auth-service)
sso-proxy.localhost:443 {
    tls internal

    reverse_proxy auth-service:8083 {
        header_up X-Forwarded-Proto "https"
        header_up X-Forwarded-Port  "8443"
    }
}

sso-proxy.localhost:80 {
    redir https://sso-proxy.localhost:8443{uri} permanent
}

# target-app.localhost — OIDC Auth Code + PKCE target SPA
# /api/token is proxied to Keycloak to avoid CORS on the token endpoint
# /callback is served by the SPA (handled client-side by React)
target-app.localhost:443 {
    tls internal

    handle /api/token {
        reverse_proxy keycloak:8080 {
            rewrite /realms/auth-sandbox/protocol/openid-connect/token
            header_up X-Forwarded-Proto "https"
            header_up X-Forwarded-Port  "8443"
        }
    }

    handle {
        reverse_proxy target-app:80
    }
}

target-app.localhost:80 {
    redir https://target-app.localhost:8443{uri} permanent
}

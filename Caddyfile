{
    # Caddy listens on 443 inside the container; the host maps 8443→443 and 8080→80
    http_port  80
    https_port 443
}

# HTTP → HTTPS redirect for all virtual hosts
http:// {
    redir https://{host}:8443{uri} permanent
}

# keycloak.localhost
keycloak.localhost:443 {
    tls internal

    # Keycloak sends large OIDC response headers (cookies, PAR, etc.)
    reverse_proxy keycloak:8080 {
        header_up X-Forwarded-Proto "https"
        header_up X-Forwarded-Port  "8443"
        flush_interval -1
    }
}

# auth-service.localhost
auth-service.localhost:443 {
    tls internal

    reverse_proxy auth-service:8083 {
        header_up X-Forwarded-Proto "https"
        header_up X-Forwarded-Port  "8443"
    }
}

# app-mock.localhost — mobile app mock UI
# /api/userinfo → Keycloak userinfo (same-origin, no CORS)
# /api/*        → auth-service (same-origin, no CORS)
# /             → static SPA files
app-mock.localhost:443 {
    tls internal

    handle /api/userinfo {
        rewrite * /realms/auth-sandbox/protocol/openid-connect/userinfo
        reverse_proxy keycloak:8080 {
            header_up X-Forwarded-Proto "https"
            header_up X-Forwarded-Port  "8443"
        }
    }

    handle /api/* {
        reverse_proxy auth-service:8083 {
            header_up X-Forwarded-Proto "https"
            header_up X-Forwarded-Port  "8443"
        }
    }

    handle {
        root * /srv/app-mock
        file_server
    }
}

# admin.localhost — admin panel
# /api/* → auth-service (admin endpoints, Basic Auth forwarded)
# /      → static files
admin.localhost:443 {
    tls internal

    handle /api/* {
        reverse_proxy auth-service:8083 {
            header_up X-Forwarded-Proto "https"
            header_up X-Forwarded-Port  "8443"
        }
    }

    handle {
        root * /srv/admin-mock
        file_server
    }
}

# home.localhost — developer start page
home.localhost:443 {
    tls internal

    root * /srv/home
    file_server
}

# sso-proxy.localhost — SSO browser transfer (served by auth-service)
sso-proxy.localhost:443 {
    tls internal

    reverse_proxy auth-service:8083 {
        header_up X-Forwarded-Proto "https"
        header_up X-Forwarded-Port  "8443"
    }
}

# target-app.localhost — OIDC Auth Code + PKCE target SPA
# /api/userinfo → Keycloak userinfo (avoid CORS)
# /api/token    → Keycloak token endpoint (avoid CORS)
# /             → static SPA files (SPA fallback for client-side routing)
target-app.localhost:443 {
    tls internal

    handle /api/userinfo {
        rewrite * /realms/auth-sandbox/protocol/openid-connect/userinfo
        reverse_proxy keycloak:8080 {
            header_up X-Forwarded-Proto "https"
            header_up X-Forwarded-Port  "8443"
        }
    }

    handle /api/token {
        rewrite * /realms/auth-sandbox/protocol/openid-connect/token
        reverse_proxy keycloak:8080 {
            header_up X-Forwarded-Proto "https"
            header_up X-Forwarded-Port  "8443"
        }
    }

    handle {
        root * /srv/target-app
        try_files {path} /index.html
        file_server
    }
}

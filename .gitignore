# Secrets / environment files
.env
tofu/terraform.tfvars
tofu/.terraform/
tofu/.terraform.lock.hcl
tofu/terraform.tfstate
tofu/terraform.tfstate.backup
tofu/terraform.tfstate.*.backup

# JWT key pairs (generated per environment — never commit)
device-login/keys/

# Caddy TLS data and config (auto-managed, not committed)
caddy-data/
caddy-config/

# Build artefacts
*.class
*.jar
!**/gradle/wrapper/gradle-wrapper.jar
target/
build/
bin/

# Gradle wrapper cache
.gradle/

# IDE files
.classpath
.project
.factorypath
.settings/

# Node / frontend
node_modules/

# Playwright test reports
**/playwright-report/
**/test-results/

# Copy to terraform.tfvars and fill in the sensitive values.
# Never commit terraform.tfvars to version control.

keycloak_admin_password          = "change-me-keycloak-admin-password"
device_login_client_secret       = "change-me-device-login-client-secret"
device_login_admin_client_secret = "change-me-device-login-admin-secret"
cms_client_secret               = "change-me-cms-client-secret"

# Optional overrides (defaults match .env.example)
# keycloak_url             = "https://keycloak.localhost:8443"
# keycloak_admin_username  = "admin"
# realm_id                 = "auth-sandbox"
# device_login_redirect_uri = "https://auth-service.localhost:8443/api/v1/auth/callback"
# device_login_idp_alias   = "device-login-idp"
# jwt_issuer               = "https://auth-service.localhost:8443"
# device_login_jwks_url    = "https://auth-service.localhost:8443/api/v1/auth/.well-known/jwks.json"

# CMS Mock
# cms_callback_uri         = "https://cms.localhost:8443/cms/callback"
# cms_public_redirect_uri  = "https://cms.localhost:8443/cms-content/index.html"
# cms_premium_redirect_uri = "https://cms.localhost:8443/cms-content/premium.html"
# cms_admin_redirect_uri   = "https://cms.localhost:8443/cms-content/admin.html"

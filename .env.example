# Shared PostgreSQL instance
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=change-me-keycloak-db-password

# Keycloak admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password

# auth-service DB user (schema: device_login inside the shared DB)
DEVICE_POSTGRES_USER=device_login
DEVICE_POSTGRES_PASSWORD=change-me-device-login-db-password

# auth-service JWT
JWT_ISSUER=https://auth-service.localhost:8443
JWT_EXPIRATION_SECONDS=300
TRANSFER_TOKEN_TTL_SECONDS=60
CHALLENGE_EXPIRATION_SECONDS=120

# Keycloak OIDC client (shared by device-login auth flow and SSO transfer)
KEYCLOAK_REALM_URL=https://keycloak.localhost:8443/realms/auth-sandbox
KEYCLOAK_AUTH_ENDPOINT=http://keycloak:8080/realms/auth-sandbox/protocol/openid-connect/auth
KEYCLOAK_AUTH_PUBLIC_ENDPOINT=https://keycloak.localhost:8443/realms/auth-sandbox/protocol/openid-connect/auth
KEYCLOAK_TOKEN_ENDPOINT=http://keycloak:8080/realms/auth-sandbox/protocol/openid-connect/token
KEYCLOAK_PAR_ENDPOINT=http://keycloak:8080/realms/auth-sandbox/protocol/openid-connect/ext/par/request
KEYCLOAK_INTROSPECT_ENDPOINT=http://keycloak:8080/realms/auth-sandbox/protocol/openid-connect/token/introspect
KEYCLOAK_CLIENT_ID=device-login-client
KEYCLOAK_CLIENT_SECRET=change-me-device-login-client-secret
KEYCLOAK_REDIRECT_URI=https://auth-service.localhost:8443/api/v1/auth/callback
KEYCLOAK_CALLBACK_URI=https://auth-service.localhost:8443/api/v1/transfer/callback
KEYCLOAK_SCOPE=openid profile
KEYCLOAK_ASSERTION_EXPIRATION_SECONDS=60

# Keycloak admin API
KEYCLOAK_ADMIN_CLIENT_ID=device-login-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-device-login-admin-secret
KEYCLOAK_ADMIN_REALM=auth-sandbox
KEYCLOAK_IDP_ALIAS=device-login-idp
KEYCLOAK_SSO_PROXY_IDP_ALIAS=device-login-idp
KEYCLOAK_ADMIN_TOKEN_ENDPOINT=http://keycloak:8080/realms/auth-sandbox/protocol/openid-connect/token
KEYCLOAK_ADMIN_BASE_URL=http://keycloak:8080

# CMS Mock — cms-client (CONFIDENTIAL, server-seitiger Code-Exchange)
KEYCLOAK_CMS_CLIENT_ID=cms-client
KEYCLOAK_CMS_CLIENT_SECRET=change-me-cms-client-secret
KEYCLOAK_CMS_CALLBACK_URI=https://cms.localhost:8443/cms/callback
KEYCLOAK_CMS_USERINFO_ENDPOINT=http://keycloak:8080/realms/auth-sandbox/protocol/openid-connect/userinfo
KEYCLOAK_CMS_AUTH_PUBLIC_ENDPOINT=https://keycloak.localhost:8443/realms/auth-sandbox/protocol/openid-connect/auth
KEYCLOAK_CMS_TOKEN_ENDPOINT=http://keycloak:8080/realms/auth-sandbox/protocol/openid-connect/token

# Shared PostgreSQL instance
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=change-me-keycloak-db-password

# Keycloak admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password

# device-login DB user (schema: device_login inside the shared DB)
DEVICE_POSTGRES_USER=device_login
DEVICE_POSTGRES_PASSWORD=change-me-device-login-db-password

# device-login JWT
JWT_ISSUER=https://device-login.localhost:8443
JWT_EXPIRATION_SECONDS=300
CHALLENGE_EXPIRATION_SECONDS=120

# Keycloak OIDC client (device-login auth flow)
KEYCLOAK_REALM_URL=https://keycloak.localhost:8443/realms/auth-sandbox
KEYCLOAK_AUTH_ENDPOINT=http://keycloak:8080/realms/auth-sandbox/protocol/openid-connect/auth
KEYCLOAK_TOKEN_ENDPOINT=http://keycloak:8080/realms/auth-sandbox/protocol/openid-connect/token
KEYCLOAK_CLIENT_ID=device-login-client
KEYCLOAK_CLIENT_SECRET=change-me-device-login-client-secret
KEYCLOAK_REDIRECT_URI=https://device-login.localhost:8443/api/v1/auth/callback
KEYCLOAK_SCOPE=openid profile
KEYCLOAK_ASSERTION_EXPIRATION_SECONDS=60
KEYCLOAK_ADMIN_CLIENT_ID=device-login-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-device-login-admin-secret
KEYCLOAK_ADMIN_REALM=auth-sandbox
KEYCLOAK_IDP_ALIAS=device-login-idp
KEYCLOAK_ADMIN_TOKEN_ENDPOINT=http://keycloak:8080/realms/auth-sandbox/protocol/openid-connect/token
KEYCLOAK_ADMIN_BASE_URL=http://keycloak:8080
